# VS Code rewrites this with machine state (mssql connections/tokens) — never track it
vscode/.config/Code/User/settings.json

# Dictation venv is machine-built by setup.sh (faster-whisper + CUDA wheels + model cache)
dictation/.local/share/dictation/venv/

# Zellij's config UI ("Save to disk") rewrites config.kdl as a full dump and
# leaves a .bak — never track those; the lean hand-written config.kdl is canonical.
zellij/.config/zellij/*.bak

# yazi flavors are fetched by `ya pkg add`, not tracked
yazi/.config/yazi/flavors/

# jj sandbox: colocated jj metadata in this repo (try jj without touching git history)
.jj/
# jj stores per-repo state under the (stowed) ~/.config/jj/repos — machine-specific
jj/.config/jj/repos/

# --- Never commit secrets (this repo is PUBLIC) ------------------------------
# Defensive: none of these belong in a stow package, but guard against an
# accidental `git add -A` ever pulling a credential file into history.
**/id_rsa
**/id_ed25519
**/id_ecdsa
**/*.pem
**/*.key
**/*.p12
**/*.pfx
**/*.kdbx
**/*.ovpn
**/rclone.conf
**/.netrc
**/.pgpass
**/.ssh/
**/.gnupg/
**/*.age
secrets/
*.secret
