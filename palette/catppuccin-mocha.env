# Canonical Catppuccin Mocha palette — source of truth for all TEMPLATED (*.in)
# configs. Hex values WITHOUT a leading '#'. Theme templates reference these as
# ${ctp_<name>} and are rendered to their real files by palette/render.sh
# (run in bootstrap; verified in sync by the pre-commit hook).
# NOT covered: ghostty, btop, yazi, nvim and bat/fzf (zshrc) theme themselves
# via upstream Catppuccin ports — editing this file won't propagate to them.
#
# To change the palette, edit here and run: palette/render.sh
ctp_rosewater=f5e0dc
ctp_flamingo=f2cdcd
ctp_pink=f5c2e7
ctp_mauve=cba6f7
ctp_red=f38ba8
ctp_maroon=eba0ac
