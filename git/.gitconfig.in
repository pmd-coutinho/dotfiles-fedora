[user]
	name = Pedro Coutinho
	email = pmd.coutinho@gmail.com
	# "@Github" ed25519 key, served by KeePassXC via the ssh-agent user unit
	signingkey = key::ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIK8YxI4GHkNBE0ZLNzZC3rFU/1s6GxRjcsXoau5WjoPN

[gpg]
	format = ssh

[gpg "ssh"]
	# lets `git log --show-signature` verify locally
	allowedSignersFile = ~/.config/git/allowed_signers

[commit]
	gpgsign = true

[core]
	editor = nvim
	pager = delta
	# big working trees (NopCommerce) — let git use the fs monitor + cache
	fsmonitor = true
	untrackedCache = true

[init]
	defaultBranch = main

[pull]
	rebase = true

[fetch]
	prune = true

[push]
	autoSetupRemote = true
	default = current

[diff]
	algorithm = histogram
	colorMoved = default

[merge]
	conflictStyle = zdiff3

# mergiraf: syntax-aware merge that auto-resolves structural conflicts.
# Activated per-language via ~/.config/git/attributes (merge=mergiraf).
[merge "mergiraf"]
	name = mergiraf
	driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L

[rerere]
	enabled = true

[branch]
	sort = -committerdate

[column]
	ui = auto

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true
	syntax-theme = Catppuccin Mocha
	features = catppuccin-mocha

[delta "catppuccin-mocha"]
	# the four diff-background blends are deliberate non-palette mixes (palette
	# red/green blended toward base) — keep literal even if the palette changes
	minus-style                   = syntax "#443244"
	minus-emph-style              = syntax "#56344a"
	plus-style                    = syntax "#2c3b3a"
	plus-emph-style               = syntax "#3a4f44"
	line-numbers-minus-style      = "#${ctp_red}"
	line-numbers-plus-style       = "#${ctp_green}"
	line-numbers-zero-style       = "#${ctp_overlay0}"
	line-numbers-left-style       = "#${ctp_surface0}"
	line-numbers-right-style      = "#${ctp_surface0}"
	file-style                    = "#${ctp_mauve}" bold
	file-decoration-style         = "#${ctp_mauve}" ul
	hunk-header-style             = "#${ctp_blue}" bold
	hunk-header-decoration-style  = "#${ctp_surface1}" box
	blame-palette                 = "#${ctp_base}" "#${ctp_mantle}" "#${ctp_surface0}" "#${ctp_surface1}"

[alias]
	st = status
	co = checkout
	sw = switch
	br = branch
	ci = commit
	cm = commit -m
	amend = commit --amend --no-edit
	unstage = restore --staged
	last = log -1 HEAD --stat
	df = diff
	dc = diff --cached
	lg = log --graph --abbrev-commit --decorate --all \
		--format=format:'%C(bold blue)%h%C(reset) %C(dim white)%an%C(reset)%C(auto)%d%C(reset) %C(white)%s%C(reset) %C(dim white)(%ar)%C(reset)'
	pf = push --force-with-lease
	# structural (syntax-aware) diff on demand; plain `git diff` stays delta
	dft = -c diff.external=difft diff
