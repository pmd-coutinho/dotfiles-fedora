/* SwayNC — Catppuccin Mocha, matching the waybar island language */

@define-color base     #${ctp_base};
@define-color mantle   #${ctp_mantle};
@define-color crust    #${ctp_crust};
@define-color surface0 #${ctp_surface0};
@define-color surface1 #${ctp_surface1};
@define-color overlay0 #${ctp_overlay0};
@define-color text     #${ctp_text};
@define-color subtext  #${ctp_subtext0};
@define-color mauve    #${ctp_mauve};
@define-color lavender #${ctp_lavender};
@define-color blue     #${ctp_blue};
@define-color green    #${ctp_green};
@define-color peach    #${ctp_peach};
@define-color red      #${ctp_red};

* {
    font-family: "JetBrainsMono Nerd Font", monospace;
}

/* ── Floating notification popups ── */
.notification-row {
    outline: none;
    margin: 6px 10px 0 0;
}

.notification {
    background: alpha(@base, 0.96);
    border: 1px solid alpha(@surface0, 0.9);
    border-radius: 12px;
    box-shadow: 0 4px 16px alpha(@crust, 0.55);
    padding: 0;
}

.notification.critical {
    border: 1px solid @red;
}

.notification-content {
    background: transparent;
    padding: 8px;
    border-radius: 12px;
}

.notification-default-action,
.notification-action {
    background: transparent;
    border: none;
    color: @text;
    transition: background 0.15s ease;
}

.notification-default-action:hover,
.notification-action:hover {
    background: alpha(@surface0, 0.6);
    border-radius: 12px;
}

.notification-action {
    border-radius: 8px;
    margin: 4px;
    background: alpha(@surface0, 0.5);
}

.close-button {
    background: @surface0;
    color: @subtext;
    border-radius: 8px;
    margin: 6px;
    padding: 0;
    min-width: 22px;
    min-height: 22px;
}

.close-button:hover {
    background: @red;
    color: @crust;
}

.summary {
    color: @text;
    font-weight: 700;
    font-size: 14px;
}

.body {
    color: @subtext;
    font-size: 13px;
}

.time {
    color: @overlay0;
    font-size: 11px;
}

.notification image {
    border-radius: 8px;
}

/* ── Control center ── */
.control-center {
    background: alpha(@mantle, 0.96);
    border: 1px solid alpha(@surface0, 0.9);
    border-radius: 12px;
    box-shadow: 0 8px 28px alpha(@crust, 0.6);
    margin: 0;
    padding: 12px;
}

.control-center .notification {
    box-shadow: none;
}

.widget-title {
    color: @lavender;
    font-weight: 700;
    font-size: 14px;
    margin: 10px 0 4px 0;
}

.widget-title > button {
    background: @surface0;
    color: @subtext;
    border: none;
    border-radius: 8px;
    padding: 4px 10px;
    font-size: 12px;
}

.widget-title > button:hover {
    background: @red;
    color: @crust;
}

/* DND switch row */
.widget-dnd {
    color: @text;
    font-weight: 700;
    font-size: 13px;
    margin: 4px 0;
}

.widget-dnd > switch {
    background: @surface0;
    border-radius: 10px;
    border: none;
}

.widget-dnd > switch:checked {
    background: @mauve;
}

.widget-dnd > switch slider {
    background: @text;
    border-radius: 8px;
}

/* Quick-toggle grid */
.widget-buttons-grid {
    background: transparent;
    padding: 4px 0;
    margin: 4px 0;
}

.widget-buttons-grid > flowbox > flowboxchild > button {
    background: alpha(@surface0, 0.7);
    color: @subtext;
    border: 1px solid transparent;
    border-radius: 12px;
    min-width: 70px;
    min-height: 44px;
    font-size: 17px;
    transition: all 0.15s ease;
}

.widget-buttons-grid > flowbox > flowboxchild > button:hover {
    background: @surface1;
    color: @text;
}

.widget-buttons-grid > flowbox > flowboxchild > button.toggle:checked {
    background: @mauve;
    color: @crust;
}

/* Media player */
.widget-mpris {
    background: transparent;
    padding: 0;
}

.widget-mpris-player {
    background: alpha(@base, 0.9);
    border: 1px solid alpha(@surface0, 0.9);
    border-radius: 12px;
    padding: 10px;
    margin: 4px 0;
}

.widget-mpris-title {
    color: @text;
    font-weight: 700;
}

.widget-mpris-subtitle {
    color: @subtext;
    font-size: 12px;
}

.widget-mpris button {
    color: @subtext;
    border-radius: 8px;
}

.widget-mpris button:hover {
    background: @surface0;
    color: @text;
}

.widget-inhibitors {
    color: @text;
    font-weight: 700;
}

.notification-group-headers {
    color: @subtext;
}

.notification-group-collapse-button,
.notification-group-close-all-button {
    background: @surface0;
    color: @subtext;
    border-radius: 8px;
    margin: 2px;
}

.notification-group-collapse-button:hover,
.notification-group-close-all-button:hover {
    background: @surface1;
    color: @text;
}
