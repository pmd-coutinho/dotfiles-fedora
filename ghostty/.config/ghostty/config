# Ghostty — Catppuccin Mocha
theme = Catppuccin Mocha
font-family = CaskaydiaCove Nerd Font
font-size = 14

window-padding-x = 8
window-padding-y = 8
window-decoration = false

cursor-style = bar
mouse-hide-while-typing = true

# Under zellij (mouse_mode true) the app grabs the mouse, so clicks on links
# go to zellij instead of ghostty. Forcing shift-capture off makes Shift the
# universal override: Shift+Click reaches ghostty and opens links / selects
# text, while plain mouse still drives zellij scroll + pane focus.
mouse-shift-capture = false

command = /usr/bin/zsh

# Match niri/GTK dark
window-theme = dark
gtk-single-instance = true
confirm-close-surface = false

# Shift+Enter sends ESC+CR (newline in Claude Code etc.)
keybind = shift+enter=text:\x1b\r
