/* Walker — Catppuccin Mocha
 * Inherits the default theme's layout.xml; overrides colors + shape only,
 * matching the waybar/swaync/walker 12px-radius island language. */

@define-color base     #${ctp_base};
@define-color mantle   #${ctp_mantle};
@define-color crust    #${ctp_crust};
@define-color surface0 #${ctp_surface0};
@define-color surface1 #${ctp_surface1};
@define-color overlay0 #${ctp_overlay0};
@define-color text     #${ctp_text};
@define-color subtext  #${ctp_subtext0};
@define-color mauve    #${ctp_mauve};
@define-color blue     #${ctp_blue};
@define-color red      #${ctp_red};

* {
    font-family: "JetBrainsMono Nerd Font", monospace;
    font-size: 14px;
}

/* Dim the area behind the launcher */
window {
    background: transparent;
}

.box-wrapper {
    background: alpha(@base, 0.97);
    border: 1px solid @surface1;
    border-radius: 12px;
    box-shadow: 0 12px 40px alpha(@crust, 0.6);
    padding: 8px;
}

.search-container {
    background: transparent;
    padding: 4px;
}

.input {
    background: @mantle;
    color: @text;
    border: 1px solid @surface0;
    border-radius: 10px;
    padding: 10px 14px;
    margin: 4px;
    caret-color: @mauve;
}

.input placeholder {
    color: @overlay0;
}

.list {
    background: transparent;
    margin-top: 4px;
}

.item-box {
    background: transparent;
    border-radius: 10px;
    padding: 8px 12px;
    margin: 2px 4px;
}

.item-text {
    color: @text;
}

.item-subtext {
    color: @subtext;
    font-size: 12px;
}

child:selected .item-box,
row:selected .item-box {
    background: alpha(@mauve, 0.18);
    border: 1px solid alpha(@mauve, 0.5);
}

child:selected .item-text,
row:selected .item-text {
    color: @text;
}

.normal-icons {
    -gtk-icon-size: 20px;
}

.large-icons {
    -gtk-icon-size: 32px;
}

/* Calc / hint / error accents */
.calc {
    color: @blue;
}

.placeholder,
.elephant-hint {
    color: @overlay0;
}

.error {
    color: @red;
}

/* Keybind hints at the bottom */
.keybinds {
    margin-top: 6px;
}

.keybind-button {
    background: @surface0;
    color: @subtext;
    border-radius: 8px;
    padding: 2px 8px;
}

.keybind-label {
    color: @overlay0;
}
