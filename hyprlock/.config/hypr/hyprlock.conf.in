# hyprlock — Catppuccin Mocha
# Blurred screenshot background, clock + date, mauve-accented input field.

$base     = rgb(${ctp_base})
$surface0 = rgb(${ctp_surface0})
$text     = rgb(${ctp_text})
$subtext  = rgb(${ctp_subtext0})
$mauve    = rgb(${ctp_mauve})
$red      = rgb(${ctp_red})
$green    = rgb(${ctp_green})

$font = JetBrainsMono Nerd Font

general {
    hide_cursor = true
}

background {
    monitor =
    path = screenshot
    blur_passes = 3
    blur_size = 6
    noise = 0.012
    brightness = 0.55
    vibrancy = 0.17
}

# Clock
label {
    monitor =
    # minute-granularity updates: per-second redraws can keep the
    # compositor from letting powered-off monitors stay off
    text = cmd[update:60000] date +"%H:%M"
    color = $text
    font_size = 96
    font_family = $font
    position = 0, 160
    halign = center
    valign = center
}

# Date
label {
    monitor =
    text = cmd[update:60000] date +"%A, %d %B"
    color = $subtext
    font_size = 20
    font_family = $font
    position = 0, 60
    halign = center
    valign = center
}

# Password field
input-field {
    monitor =
    size = 280, 52
    rounding = 12
    outline_thickness = 2
    outer_color = $mauve
    inner_color = $surface0
    font_color = $text
    font_family = $font
    placeholder_text = <i>password…</i>
    check_color = $green
    fail_color = $red
    fail_text = <i>nope ($ATTEMPTS)</i>
    dots_size = 0.25
    dots_spacing = 0.3
    fade_on_empty = false
    position = 0, -80
    halign = center
    valign = center
}

# User hint
label {
    monitor =
    text =   $USER
    color = $subtext
    font_size = 14
    font_family = $font
    position = 0, -150
    halign = center
    valign = center
}
