// dev.kdl — agent workspace layout.
//   tab "claude": auto-runs Claude Code
//   tab "shell":  plain zsh
//
// Launch from a project root (both tabs inherit that directory):
//     zellij -s <ticket> -n dev
// Use -n (--new-session-with-layout), NOT --layout: with -s, --layout tries
// to add tabs to an *existing* session and fails with "session not found".
//
// `claude` resolves via the mise PATH inherited from the zsh you launch
// zellij from. When claude exits, Zellij keeps the pane so you can re-run it.

layout {
    // Custom layout replaces the default UI. Top = zjstatus (session, tabs, git
    // branch, clock); bottom = Zellij's status-bar (keeps the live keymap hints).
    // Plugins fetch + cache from their pinned URLs on first use.
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="https://github.com/dj95/zjstatus/releases/download/v0.21.0/zjstatus.wasm" {
                format_left  "#[fg=#cba6f7,bold] {session} {tabs}"
                format_right "{command_git}#[fg=#89b4fa,bold] {datetime}"
                format_space ""
                border_enabled "false"

                tab_normal "#[fg=#6c7086] {name} "
                tab_active "#[fg=#1e1e2e,bg=#cba6f7,bold] {name} "

                command_git_command    "git rev-parse --abbrev-ref HEAD"
                command_git_format     "#[fg=#a6e3a1] {stdout} "
                command_git_interval   "5"
                command_git_rendermode "static"

                datetime          "#[fg=#89b4fa,bold]{format}"
                datetime_format   "%a %d %b %H:%M"
                datetime_timezone "Europe/Lisbon"
            }
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="claude" focus=true {
        pane command="claude"
    }
    tab name="shell" {
        pane
    }
}
