// Zellij — Catppuccin Mocha, Wayland clipboard, zsh.
// Managed via ~/dotfiles (GNU Stow): stow package `zellij`.
//
// Keybinds are intentionally left at Zellij defaults — but the live keymap is
// NOT shown via the built-in status-bar (it can't pick which keys to show and
// looked cluttered). Instead both layouts render a curated zjstatus bottom bar
// with the most-used Ctrl-mode keys + a live {mode} indicator. The only keybind
// additions are two session-mode launchers (Ctrl-o g / Ctrl-o s) below.

// Zellij's built-in catppuccin-mocha IS the official Catppuccin palette —
// same hexes as the FZF colors in .zshrc, so it matches the rest of the rig.
theme "catppuccin-mocha"

default_shell "zsh"

// Wayland clipboard — same choice as tmux.conf's `copy-pipe-and-cancel wl-copy`.
copy_command "wl-copy"
copy_clipboard "system"
copy_on_select true

mouse_mode true
// No pane frames — cleaner look. Panes are still distinguishable by position;
// the focused pane is highlighted. Toggle on at runtime with the pane-mode `z`.
pane_frames false
scrollback_editor "/usr/bin/nvim"

// Persist sessions across detach/exit so they survive a crash or reboot
// (this is the "stop losing track of sessions" bit). Resurrect with
// `zellij attach` or pick from `zellij ls`.
session_serialization true

// ── zellij-autolock ───────────────────────────────────────────────────
// Auto-switch to Locked mode when the focused pane runs a full-screen TUI
// (nvim/fzf/lazygit/less/man) so their keys pass straight through; unlock when
// the command exits. Plugin is fetched + cached from its pinned release URL on
// first use. Manual override: Alt-z disables autolock (stay unlocked),
// Alt-Shift-z re-enables it. FIRST LAUNCH prompts to grant plugin perms — press y.
plugins {
    autolock location="https://github.com/fresh2dev/zellij-autolock/releases/download/0.2.2/zellij-autolock.wasm" {
        is_enabled true
        triggers "nvim|vim|fzf|lazygit|less|man"
        reaction_seconds "0.3"
        print_to_log false
    }
}
load_plugins {
    autolock
}
keybinds {
    normal {
        // Re-assess the lock state right after a command is launched.
        bind "Enter" {
            WriteChars "\u{000D}"
            MessagePlugin "autolock"
        }
    }
    locked {
        bind "Alt z" {
            MessagePlugin "autolock" {
                payload "disable"
            }
            SwitchToMode "Normal"
        }
    }
    shared {
        bind "Alt Shift z" {
            MessagePlugin "autolock" {
                payload "enable"
            }
        }
    }
    // Launch the zsh sessionizers in a floating pane from ANY pane — including a
    // Claude/TUI tab where there's no shell prompt to type them at. Ctrl-o is
    // already "session" mode, so these read as session ops and steal no global
    // keys. `zsh -i` so ~/.zshrc is sourced and the zp/zdl functions exist.
    session {
        bind "g" {   // Ctrl-o g → zp (project → ticket sessionizer)
            Run "zsh" "-i" "-c" "zp" {
                floating true
                close_on_exit true
            }
            SwitchToMode "Normal"
        }
        bind "s" {   // Ctrl-o s → zdl (session picker: attach / delete)
            Run "zsh" "-i" "-c" "zdl" {
                floating true
                close_on_exit true
            }
            SwitchToMode "Normal"
        }
    }
}
