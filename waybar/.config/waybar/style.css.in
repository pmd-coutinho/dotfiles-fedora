/* Waybar — Catppuccin Mocha "floating islands"
 * Three pill groups float over the wallpaper; 12px radius matches the
 * niri window corners. Mauve is the only loud accent. */

@define-color base     #${ctp_base};
@define-color mantle   #${ctp_mantle};
@define-color crust    #${ctp_crust};
@define-color surface0 #${ctp_surface0};
@define-color surface1 #${ctp_surface1};
@define-color overlay0 #${ctp_overlay0};
@define-color text     #${ctp_text};
@define-color subtext  #${ctp_subtext0};
@define-color mauve    #${ctp_mauve};
@define-color pink     #${ctp_pink};
@define-color lavender #${ctp_lavender};
@define-color blue     #${ctp_blue};
@define-color teal     #${ctp_teal};
@define-color green    #${ctp_green};
@define-color yellow   #${ctp_yellow};
@define-color peach    #${ctp_peach};
@define-color red      #${ctp_red};

* {
    font-family: "JetBrainsMono Nerd Font", monospace;
    font-size: 13px;
    font-weight: 500;
    min-height: 0;
}

window#waybar {
    background: transparent;
    color: @text;
}

/* ── The three islands ── */
.modules-left,
.modules-center,
.modules-right {
    background: alpha(@base, 0.92);
    border: 1px solid alpha(@surface0, 0.9);
    border-radius: 12px;
    padding: 0 6px;
    box-shadow: 0 4px 12px alpha(@crust, 0.5);
}

/* ── Workspaces ── */
#workspaces {
    padding: 0;
}

#workspaces button {
    padding: 0 7px;
    margin: 4px 2px;
    border-radius: 8px;
    color: @overlay0;
    background: transparent;
    transition: all 0.2s cubic-bezier(0.55, 0, 0.28, 1.68);
}

#workspaces button.active {
    color: @crust;
    background: @mauve;
    padding: 0 14px;
}

#workspaces button.urgent {
    color: @crust;
    background: @red;
}

#workspaces button:hover {
    color: @text;
    background: @surface0;
    box-shadow: none;
    text-shadow: none;
}

/* ── Window title ── */
#window {
    padding: 0 12px;
    color: @subtext;
    font-style: italic;
}

window#waybar.empty #window {
    background: transparent;
}

/* ── Clock ── */
#clock {
    padding: 0 16px;
    color: @lavender;
    font-weight: 700;
}

/* ── Right island modules ── */
#tray,
#cpu,
#memory,
#pulseaudio,
#bluetooth,
#network,
#battery,
#mpris,
#custom-powerprofile,
#custom-nightlight,
#custom-notification {
    padding: 0 10px;
    margin-right: 8px;
    color: @subtext;
}

#custom-powerprofile {
    color: @yellow;
}

#custom-nightlight     { color: @peach; }
#custom-nightlight.off { color: @overlay0; }

#mpris {
    color: @pink;
    font-style: italic;
}

#mpris.paused {
    color: @overlay0;
}

#tray {
    padding-right: 6px;
}

#tray > .passive {
    -gtk-icon-effect: dim;
}

#cpu.warning,    #memory.warning  { color: @peach; }
#cpu.critical,   #memory.critical { color: @red; }

#pulseaudio        { color: @teal; }
#pulseaudio.muted  { color: @overlay0; }

#bluetooth           { color: @blue; }
#bluetooth.disabled  { color: @overlay0; }

#network              { color: @green; }
#network.disconnected { color: @overlay0; }

#battery          { color: @green; }
#battery.warning  { color: @peach; }

#battery.critical:not(.charging) {
    color: @red;
    animation: battery-blink 1s steps(4) infinite alternate;
}

@keyframes battery-blink {
    to { color: @crust; background: @red; border-radius: 8px; }
}

#battery.charging { color: @yellow; }

#custom-notification {
    color: @mauve;
    padding-right: 14px;
    font-size: 14px;
}

/* dividers grouping the right-island modules */
#cpu, #pulseaudio, #custom-powerprofile, #custom-notification {
    border-left: 1px solid alpha(@surface0, 0.8);
}

tooltip {
    background: @mantle;
    border: 1px solid @surface0;
    border-radius: 12px;
}

tooltip label {
    color: @text;
    padding: 4px;
}
