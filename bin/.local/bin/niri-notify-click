#!/usr/bin/env python3
"""
niri-notify-click — focus a notification's originating app when you click it.

Many apps (Slack, etc.) send a notification with a "default" action but don't
actually raise their window when it fires under Wayland/niri. swaync delivers
the click correctly (ActionInvoked + an activation token); the app just ignores
it. This daemon does the raise ourselves, for every app:

  1. Eavesdrop the session bus (BecomeMonitor).
  2. On each Notify call, remember the originating app (desktop-entry hint, or
     app_name) keyed by the notification id returned by swaync.
  3. On ActionInvoked for that id, look up the app and focus its niri window
     (`niri msg action focus-window --id`), which also switches to its
     workspace/monitor.

Passive monitor connection — it only ever reads from the bus and shells out to
`niri msg`, so it can't interfere with notification delivery.
"""
import collections
import json
import subprocess

import dbus
import dbus.lowlevel
from dbus.mainloop.glib import DBusGMainLoop
from gi.repository import GLib

NOTIFY_IFACE = "org.freedesktop.Notifications"

# call (sender, serial) -> app hint, awaiting the method_return that carries the id
pending = {}
# notification id -> app hint (bounded LRU)
id2app = collections.OrderedDict()


def remember(nid, app):
    if not app:
        return
    id2app[nid] = app
    while len(id2app) > 256:
        id2app.popitem(last=False)


def norm(s):
    s = (s or "").lower()
    return s[:-8] if s.endswith(".desktop") else s


def find_window(app):
    """Return the niri window id whose app_id best matches `app`, or None."""
    try:
        wins = json.loads(subprocess.check_output(["niri", "msg", "--json", "windows"]))
    except Exception:
        return None
    a = norm(app)
    a_leaf = a.split(".")[-1]
    fuzzy = None
    for w in wins:
        aid = norm(w.get("app_id", ""))
        if not aid:
            continue
        if aid == a:
            return w["id"]  # exact app_id == desktop-entry wins outright
        leaf = aid.split(".")[-1]
        if a_leaf and (a_leaf == leaf or a_leaf == aid or a == leaf or a in aid or aid in a):
            fuzzy = fuzzy or w["id"]
    return fuzzy


def focus(app):
    wid = find_window(app)
    if wid is not None:
        subprocess.run(["niri", "msg", "action", "focus-window", "--id", str(wid)],
                       check=False)


def msg_filter(_conn, msg):
    try:
        t = msg.get_type()
        if (t == dbus.lowlevel.MESSAGE_TYPE_METHOD_CALL
                and msg.get_interface() == NOTIFY_IFACE
                and msg.get_member() == "Notify"):
            args = msg.get_args_list()
            # Notify(app_name, replaces_id, icon, summary, body, actions, hints, timeout)
            app_name = str(args[0]) if args else ""
            hints = args[6] if len(args) > 6 else {}
            de = str(hints.get("desktop-entry", "")) if hints else ""
            app = de or app_name
            if app:
                pending[(msg.get_sender(), msg.get_serial())] = app

        elif t == dbus.lowlevel.MESSAGE_TYPE_METHOD_RETURN:
            key = (msg.get_destination(), msg.get_reply_serial())
            app = pending.pop(key, None)
            if app is not None:
                args = msg.get_args_list()
                if args:
                    remember(int(args[0]), app)

        elif (t == dbus.lowlevel.MESSAGE_TYPE_SIGNAL
              and msg.get_interface() == NOTIFY_IFACE
              and msg.get_member() == "ActionInvoked"):
            args = msg.get_args_list()
            app = id2app.get(int(args[0]))
            if app:
                focus(app)
    except Exception:
        pass  # never let a parse error kill the monitor


def main():
    DBusGMainLoop(set_as_default=True)
    bus = dbus.SessionBus()
    bus.add_message_filter(msg_filter)
    rules = [
        "type='method_call',interface='%s',member='Notify'" % NOTIFY_IFACE,
        "type='method_return'",
        "type='signal',interface='%s',member='ActionInvoked'" % NOTIFY_IFACE,
    ]
    bus.call_blocking("org.freedesktop.DBus", "/org/freedesktop/DBus",
                      "org.freedesktop.DBus.Monitoring", "BecomeMonitor",
                      "asu", (rules, dbus.UInt32(0)))
    GLib.MainLoop().run()


if __name__ == "__main__":
    main()
